class TablePrinter {
    public synchronized void printTable(int number) {
        for (int i = 1; i <= 10; i++) {
            System.out.println(Thread.currentThread().getName() + 
                             ": " + number + " x " + i + " = " + (number * i));
            try {
                Thread.sleep(100);
            } catch (InterruptedException e) {
                System.out.println("Thread interrupted");
            }
        }
    }
}

class TableThread extends Thread {
    private TablePrinter printer;
    private int number;
    
    public TableThread(TablePrinter printer, int number, String name) {
        super(name);
        this.printer = printer;
        this.number = number;
    }
    
    public void run() {
        printer.printTable(number);
    }
}

public class MultiplicationTable {
    public static void main(String[] args) {
        System.out.println("S.P.B. Patel Engineering College");
        System.out.println("Object Oriented Programming [BE04000231]");
        System.out.println("Practical 41 - Synchronized Multiplication Tables");
        System.out.println();
        
        TablePrinter printer = new TablePrinter();
        
        TableThread t1 = new TableThread(printer, 5, "Table-5");
        TableThread t2 = new TableThread(printer, 7, "Table-7");
        
        t1.start();
        t2.start();
    }
}

apack/A.java 
package apack;

public class A {
    public int pubVar;
    protected int protVar;
    private int privVar;
    
    public A(int pubVar, int protVar, int privVar) {
        this.pubVar = pubVar;
        this.protVar = protVar;
        this.privVar = privVar;
    }
}
bpack/B.java
package bpack;
import apack.A;

public class B extends A {
    public B(int pubVar, int protVar, int privVar) {
        super(pubVar, protVar, privVar);
    }
    
    public void display() {
        System.out.println("Class B (extends A) - Accessing variables:");
        System.out.println("pubVar: " + pubVar);      // Accessible (public)
        System.out.println("protVar: " + protVar);    // Accessible (protected, inheritance)
        // System.out.println("privVar: " + privVar); // ERROR: private not accessible
        System.out.println("---");
    }
}

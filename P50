import java.util.LinkedList;

public class GenericSearchDemo {
    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }
    
    public static void main(String[] args) {
        System.out.println("S.P.B. Patel Engineering College");
        System.out.println("Object Oriented Programming [BE04000231]");
        System.out.println("Practical 51 - Generic Search");
        System.out.println();
        
        // Test with Integers
        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);
        
        System.out.println("Roll Numbers: " + rollNumbers);
        System.out.println("Search 102: " + searchElement(rollNumbers, 102));
        System.out.println("Search 999: " + searchElement(rollNumbers, 999));
        
        // Test with Strings
        LinkedList<String> names = new LinkedList<>();
        names.add("Alice");
        names.add("Bob");
        names.add("Charlie");
        
        System.out.println("\nNames: " + names);
        System.out.println("Search Bob: " + searchElement(names, "Bob"));
        System.out.println("Search David: " + searchElement(names, "David"));
    }
}
